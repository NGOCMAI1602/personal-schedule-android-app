<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:gravity="center">

    <RelativeLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_centerHorizontal="true"
        android:id="@+id/day_background_container">

        <View
            android:id="@+id/view_current_day_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_circle_blue"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_day_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="25"
            android:textSize="14sp"
            android:textColor="@color/black" />
    </RelativeLayout>

    <View
        android:id="@+id/view_task_indicator"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:background="@drawable/bg_circle_red_task"
        android:layout_below="@id/day_background_container"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="-8dp"
        android:visibility="gone" />

</RelativeLayout>